{
	"name": "dock-code-remote-ssh",
	"displayName": "dock-code Remote - SSH",
	"description": "Open folders on remote machines via SSH",
	"version": "0.0.1",
	"publisher": "dock-code",
	"license": "MIT",
	"enabledApiProposals": [
		"resolvers",
		"contribViewsRemote"
	],
	"private": true,
	"engines": {
		"vscode": "^1.95.0"
	},
	"extensionKind": [
		"ui"
	],
	"scripts": {
		"compile": "node ./node_modules/vscode/bin/compile -watch -p ./",
		"vscode:prepublish": "node ../../node_modules/gulp/bin/gulp.js --gulpfile ../../build/gulpfile.extensions.mjs compile-extension:dock-code-remote-ssh"
	},
	"activationEvents": [
		"onResolveRemoteAuthority:ssh-remote",
		"onCommand:dock-code-remote-ssh.connect",
		"onCommand:dock-code-remote-ssh.showLog"
	],
	"main": "./out/extension",
	"devDependencies": {
		"@types/node": "^22.19.15"
	},
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": true
		},
		"virtualWorkspaces": true
	},
	"contributes": {
		"resourceLabelFormatters": [
			{
				"scheme": "vscode-remote",
				"authority": "ssh-remote+*",
				"formatting": {
					"label": "${path}",
					"separator": "/",
					"tildify": true,
					"workspaceSuffix": "SSH",
					"workspaceTooltip": "Remote SSH: ${authority}"
				}
			}
		],
		"commands": [
			{
				"title": "Connect to Host...",
				"category": "Remote-SSH",
				"command": "dock-code-remote-ssh.connect"
			},
			{
				"title": "Connect to Host in Current Window...",
				"category": "Remote-SSH",
				"command": "dock-code-remote-ssh.connectInCurrentWindow"
			},
			{
				"title": "Show Log",
				"category": "Remote-SSH",
				"command": "dock-code-remote-ssh.showLog"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "dock-code-remote-ssh.connect"
				},
				{
					"command": "dock-code-remote-ssh.connectInCurrentWindow"
				},
				{
					"command": "dock-code-remote-ssh.showLog",
					"when": "remoteName == ssh-remote"
				}
			],
			"statusBar/remoteIndicator": [
				{
					"command": "dock-code-remote-ssh.connect",
					"when": "!remoteName && !virtualWorkspace",
					"group": "remote_10_ssh_1_local@1"
				},
				{
					"command": "dock-code-remote-ssh.connect",
					"when": "remoteName == ssh-remote",
					"group": "remote_10_ssh_1_open@1"
				},
				{
					"command": "dock-code-remote-ssh.showLog",
					"when": "remoteName == ssh-remote",
					"group": "remote_10_ssh_1_open@3"
				}
			]
		},
		"configuration": {
			"title": "Remote - SSH",
			"properties": {
				"remote.SSH.serverInstallPath": {
					"type": "string",
					"description": "Path on the remote where the dock-code server will be installed. Defaults to ~/.dock-code-server",
					"default": ""
				},
				"remote.SSH.serverDownloadUrl": {
					"type": "string",
					"description": "URL template for downloading the dock-code server. Use ${commit}, ${os}, ${arch} as placeholders.",
					"default": ""
				},
				"remote.SSH.defaultExtensions": {
					"type": "array",
					"description": "Extensions to install on the remote server automatically.",
					"default": [],
					"items": {
						"type": "string"
					}
				}
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/dock-code/dock-code.git"
	}
}
