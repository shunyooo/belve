{
	"name": "dock-code-remote-containers",
	"displayName": "dock-code Remote - Containers",
	"description": "Open folders in Dev Containers",
	"version": "0.0.1",
	"publisher": "dock-code",
	"license": "MIT",
	"enabledApiProposals": [
		"resolvers",
		"contribViewsRemote"
	],
	"private": true,
	"engines": {
		"vscode": "^1.95.0"
	},
	"extensionKind": [
		"ui"
	],
	"activationEvents": [
		"onResolveRemoteAuthority:dev-container",
		"onCommand:dock-code-remote-containers.openInContainer",
		"onCommand:dock-code-remote-containers.rebuildContainer",
		"onCommand:dock-code-remote-containers.showLog"
	],
	"main": "./out/extension",
	"devDependencies": {
		"@types/node": "^22.19.15"
	},
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": true
		},
		"virtualWorkspaces": true
	},
	"contributes": {
		"resourceLabelFormatters": [
			{
				"scheme": "vscode-remote",
				"authority": "dev-container+*",
				"formatting": {
					"label": "${path}",
					"separator": "/",
					"tildify": true,
					"workspaceSuffix": "Dev Container",
					"workspaceTooltip": "Dev Container"
				}
			}
		],
		"commands": [
			{
				"title": "Open Folder in Container...",
				"category": "Dev Containers",
				"command": "dock-code-remote-containers.openInContainer"
			},
			{
				"title": "Rebuild Container",
				"category": "Dev Containers",
				"command": "dock-code-remote-containers.rebuildContainer"
			},
			{
				"title": "Show Log",
				"category": "Dev Containers",
				"command": "dock-code-remote-containers.showLog"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "dock-code-remote-containers.openInContainer"
				},
				{
					"command": "dock-code-remote-containers.rebuildContainer",
					"when": "remoteName == dev-container"
				},
				{
					"command": "dock-code-remote-containers.showLog",
					"when": "remoteName == dev-container"
				}
			],
			"statusBar/remoteIndicator": [
				{
					"command": "dock-code-remote-containers.openInContainer",
					"when": "!remoteName && !virtualWorkspace",
					"group": "remote_20_container_1_local@1"
				},
				{
					"command": "dock-code-remote-containers.rebuildContainer",
					"when": "remoteName == dev-container",
					"group": "remote_20_container_1_open@2"
				},
				{
					"command": "dock-code-remote-containers.showLog",
					"when": "remoteName == dev-container",
					"group": "remote_20_container_1_open@3"
				}
			]
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/dock-code/dock-code.git"
	}
}
