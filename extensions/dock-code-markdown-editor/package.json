{
	"name": "dock-code-markdown-editor",
	"displayName": "Markdown WYSIWYG Editor",
	"description": "Notion-like WYSIWYG Markdown editor powered by Milkdown",
	"version": "0.0.1",
	"publisher": "dock-code",
	"license": "MIT",
	"engines": {
		"vscode": "*"
	},
	"main": "./out/extension",
	"extensionKind": [
		"ui",
		"workspace"
	],
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"contributes": {
		"configuration": {
			"title": "Markdown Editor",
			"properties": {
				"markdownEditor.fontSize": {
					"type": "number",
					"default": 14,
					"description": "Body font size in pixels"
				},
				"markdownEditor.lineHeight": {
					"type": "number",
					"default": 1.6,
					"description": "Line height"
				},
				"markdownEditor.h1FontSize": {
					"type": "number",
					"default": 24,
					"description": "H1 font size in pixels"
				},
				"markdownEditor.h2FontSize": {
					"type": "number",
					"default": 20,
					"description": "H2 font size in pixels"
				},
				"markdownEditor.h3FontSize": {
					"type": "number",
					"default": 17,
					"description": "H3 font size in pixels"
				}
			}
		},
		"customEditors": [
			{
				"viewType": "dock-code.markdownWysiwyg",
				"displayName": "Markdown Editor",
				"priority": "default",
				"selector": [
					{
						"filenamePattern": "*.md"
					}
				]
			}
		]
	},
	"dependencies": {
		"@milkdown/crepe": "^7.20.0"
	},
	"devDependencies": {
		"@types/vscode": "*"
	}
}
