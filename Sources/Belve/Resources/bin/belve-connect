#!/bin/bash
# belve-connect: attach or create a belve-persist session
# Usage: belve-connect --session NAME --cols N --rows N [--devcontainer --project-short ID]
#        [--workdir PATH] [--project-id UUID] [--pane-index N] [--pane-id ID]

set -euo pipefail

SESSION_NAME=""
COLS=80
ROWS=24
DEVCONTAINER=0
PROJ_SHORT=""
WORKDIR=""
PROJECT_ID=""
PANE_INDEX=0
PANE_ID=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --session) SESSION_NAME="$2"; shift 2 ;;
        --cols) COLS="$2"; shift 2 ;;
        --rows) ROWS="$2"; shift 2 ;;
        --devcontainer) DEVCONTAINER=1; shift ;;
        --project-short) PROJ_SHORT="$2"; shift 2 ;;
        --workdir) WORKDIR="$2"; shift 2 ;;
        --project-id) PROJECT_ID="$2"; shift 2 ;;
        --pane-index) PANE_INDEX="$2"; shift 2 ;;
        --pane-id) PANE_ID="$2"; shift 2 ;;
        *) shift ;;
    esac
done

[ -n "$SESSION_NAME" ] || { echo "belve-connect: --session required" >&2; exit 1; }

PERSIST="$HOME/.belve/bin/belve-persist"
SOCK="$HOME/.belve/sessions/${SESSION_NAME}.sock"
VERFILE="$HOME/.belve/sessions/${SESSION_NAME}.ver"
mkdir -p "$HOME/.belve/sessions"

# Version check: kill stale master if binary was updated
CURRENT_VER=$(md5sum "$PERSIST" 2>/dev/null | cut -d' ' -f1)
if [ -S "$SOCK" ] && [ -f "$VERFILE" ]; then
    OLD_VER=$(cat "$VERFILE" 2>/dev/null)
    if [ "$CURRENT_VER" != "$OLD_VER" ]; then
        # Binary updated — kill old master so a new one is created
        fuser -k "$SOCK" 2>/dev/null || true
        rm -f "$SOCK" "$VERFILE"
    fi
fi

# Export env vars for session-bootstrap.sh to inherit
export BELVE_SESSION=1
export BELVE_PROJECT_ID="$PROJECT_ID"
export BELVE_PANE_INDEX="$PANE_INDEX"
export BELVE_PANE_ID="$PANE_ID"
export TERM=xterm-256color

if [ "$DEVCONTAINER" = "1" ] && [ -n "$PROJ_SHORT" ]; then
    # Source cached container info (CID, RWS, CIP)
    . "$HOME/.belve/projects/${PROJ_SHORT}.env"

    # Re-query container IP if not set (older .env files)
    if [ -z "$CIP" ]; then
        CIP=$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' "$CID" | head -1)
    fi

    # Sync scripts into container (md5 check, fast if unchanged)
    for f in belve claude codex belve-persist session-bootstrap.sh; do
        src="$HOME/.belve/bin/$f"
        dst="/root/.belve/bin/$f"
        [ "$f" = "session-bootstrap.sh" ] && dst="/root/.belve/session-bootstrap.sh"
        [ -f "$src" ] || continue
        local_md5=$(md5sum "$src" 2>/dev/null | cut -d' ' -f1)
        remote_md5=$(docker exec "$CID" md5sum "$dst" 2>/dev/null | cut -d' ' -f1)
        if [ "$local_md5" != "$remote_md5" ]; then
            docker cp "$src" "$CID:$dst" 2>/dev/null
            docker exec "$CID" chmod +x "$dst" 2>/dev/null
        fi
    done

    # Ensure TCP broker is running in container (port 19222)
    if ! timeout 1 bash -c "echo > /dev/tcp/$CIP/19222" 2>/dev/null; then
        docker exec -d \
            -e BELVE_SESSION=1 \
            -e "BELVE_PROJECT_ID=$PROJECT_ID" \
            -e TERM=xterm-256color \
            -w "$RWS" \
            "$CID" /root/.belve/bin/belve-persist \
            -tcplisten 0.0.0.0:19222 \
            -command /root/.belve/session-bootstrap.sh
        # Wait for broker to be ready
        for i in $(seq 1 30); do
            timeout 1 bash -c "echo > /dev/tcp/$CIP/19222" 2>/dev/null && break
            sleep 0.2
        done
    fi

    # Attach to existing host daemon or create new one
    if [ -S "$SOCK" ]; then
        "$PERSIST" -socket "$SOCK" 2>/dev/null && exit 0
        rm -f "$SOCK"
    fi

    echo "$CURRENT_VER" > "$VERFILE"

    # Start host TCP backend daemon in background
    nohup "$PERSIST" -socket "$SOCK" -cols "$COLS" -rows "$ROWS" \
        -tcpbackend "$CIP:19222" -session "$SESSION_NAME" \
        >/dev/null 2>&1 &

    # Wait for socket to appear, then attach
    for i in $(seq 1 50); do
        [ -S "$SOCK" ] && break
        sleep 0.1
    done
    exec "$PERSIST" -socket "$SOCK"
else
    # Plain SSH: persist on HOST, bootstrap as child
    [ -n "$WORKDIR" ] && cd "$WORKDIR" 2>/dev/null || true

    # Try attach if session socket exists (non-exec so we can fallback)
    if [ -S "$SOCK" ]; then
        "$PERSIST" -socket "$SOCK" 2>/dev/null && exit 0
        rm -f "$SOCK"  # Stale socket
    fi

    # Create new session
    echo "$CURRENT_VER" > "$VERFILE"
    exec "$PERSIST" -socket "$SOCK" -cols "$COLS" -rows "$ROWS" \
        -command "$HOME/.belve/session-bootstrap.sh"
fi
