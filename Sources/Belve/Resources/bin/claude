#!/usr/bin/env bash
# Belve claude wrapper - injects hooks that call `belve claude-hook`
#
# Inside a Belve terminal (BELVE_SESSION=1), intercepts `claude` to inject
# --settings with hook commands. Outside Belve, passes through unchanged.

set -euo pipefail

find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Pass through if not in Belve
if [[ -z "${BELVE_SESSION:-}" ]]; then
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through subcommands that don't support hooks
case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

# Find belve CLI (same directory as this wrapper)
BELVE_BIN="$(cd "$(dirname "$0")" && pwd)/belve"
H="\\\"${BELVE_BIN}\\\" claude-hook"

# Always inject Belve's full hook set. Claude's --settings merges with the user's
# settings.json, so if the user defines the same hook the two run side-by-side.
# Belve wants to capture every event for the session bar — coexistence is the goal.
HOOKS_JSON="{\"hooks\":{\
\"SessionStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} session-start\",\"timeout\":5}]}],\
\"UserPromptSubmit\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} prompt-submit\",\"timeout\":5}]}],\
\"Notification\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} notification\",\"timeout\":5}]}],\
\"PreToolUse\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} pre-tool-use\",\"timeout\":3}]}],\
\"PostToolUse\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} post-tool-use\",\"timeout\":3}]}],\
\"Stop\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} stop\",\"timeout\":5}]}],\
\"SubagentStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} subagent-start\",\"timeout\":3}]}],\
\"SubagentStop\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"${H} subagent-stop\",\"timeout\":3}]}]\
}}"

exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
