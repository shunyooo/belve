#!/usr/bin/env bash
# Belve claude wrapper - injects hooks that call `belve claude-hook`
#
# Inside a Belve terminal (BELVE_SESSION=1), intercepts `claude` to inject
# --settings with hook commands. Outside Belve, passes through unchanged.

set -euo pipefail

find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Pass through if not in Belve
if [[ -z "${BELVE_SESSION:-}" ]]; then
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through subcommands that don't support hooks
case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

# Find belve CLI (same directory as this wrapper)
BELVE_BIN="$(cd "$(dirname "$0")" && pwd)/belve"

# Build hooks JSON - all hooks call `belve claude-hook <subcommand>`
HOOKS_JSON="{\"hooks\":{\"SessionStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"\\\"${BELVE_BIN}\\\" claude-hook session-start\",\"timeout\":5}]}],\"Notification\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"\\\"${BELVE_BIN}\\\" claude-hook notification\",\"timeout\":5}]}],\"UserPromptSubmit\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"\\\"${BELVE_BIN}\\\" claude-hook prompt-submit\",\"timeout\":5}]}],\"PreToolUse\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"\\\"${BELVE_BIN}\\\" claude-hook pre-tool-use\",\"timeout\":3}]}],\"Stop\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"\\\"${BELVE_BIN}\\\" claude-hook stop\",\"timeout\":5}]}],\"SessionEnd\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"\\\"${BELVE_BIN}\\\" claude-hook session-end\",\"timeout\":1}]}]}}"

exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
