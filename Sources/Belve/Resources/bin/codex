#!/usr/bin/env bash
# Belve codex wrapper. Codex は Claude Code と違い hooks を flag で渡せず
# `~/.codex/hooks.json` (file-based) で設定するため、wrapper は実行直前に
# `codex-hooks-install` を呼んで Belve エントリの merge を保証する。
# 既存の他ツール (vibe-island 等) のエントリは保持される。

set -euo pipefail

find_real_codex() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/codex" ]] && printf '%s' "$d/codex" && return 0
    done
    return 1
}

REAL_CODEX="$(find_real_codex)" || { echo "Error: codex not found in PATH" >&2; exit 127; }

# Belve session 外なら hooks 設定を触らずそのまま pass through
if [[ -z "${BELVE_SESSION:-}" ]]; then
    exec "$REAL_CODEX" "$@"
fi

# Hooks API を使わない subcommand は install を skip
case "${1:-}" in
    config|api-key|completion|version|help|--help|-h|--version|-V)
        exec "$REAL_CODEX" "$@" ;;
esac

# Belve hooks を ~/.codex/hooks.json に merge install (idempotent)。
# 失敗しても codex 起動は止めない (= hooks 連携が無いだけで codex は使える)。
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
"$SELF_DIR/codex-hooks-install" 2>/dev/null || true

exec "$REAL_CODEX" "$@"
