#!/usr/bin/env python3
# codex-hooks-install: inject Belve hooks into ~/.codex/hooks.json
#
# Idempotent + migration-safe: 自分のエントリだけを識別して入れ替える。
# 他ツール (vibe-island 等) のエントリは絶対に touch しない。
#
# 識別マーカー: command 文字列が `<HOME>/.belve/bin/belve claude-hook` で
# 始まるもの = Belve 所有。それ以外は他ツール所有。
#
# Usage:
#   codex-hooks-install                # install / upgrade
#   codex-hooks-install --uninstall    # remove Belve entries only
import json
import os
import sys
import tempfile
from pathlib import Path

HOME = Path(os.path.expanduser("~"))
CONFIG_DIR = HOME / ".codex"
HOOKS_FILE = CONFIG_DIR / "hooks.json"
BELVE_CMD_PREFIX = str(HOME / ".belve" / "bin" / "belve") + " claude-hook"

# Belve が登録する hooks 一式。Claude Code wrapper と同じ event 群。
HOOKS_SPEC = [
    ("SessionStart",     "session-start",  5),
    ("SessionEnd",       "session-end",    1),
    ("UserPromptSubmit", "prompt-submit",  5),
    ("Notification",     "notification",   5),
    ("PreToolUse",       "pre-tool-use",   3),
    ("PostToolUse",      "post-tool-use",  3),
    ("SubagentStart",    "subagent-start", 3),
    ("SubagentStop",     "subagent-stop",  3),
    ("Stop",             "stop",           5),
]


def is_belve_owned(matcher: dict) -> bool:
    """matcher の hooks 配列内に Belve のマーカーで始まる command が 1 つでもあれば True。"""
    hooks = matcher.get("hooks") or []
    if not isinstance(hooks, list):
        return False
    for h in hooks:
        if not isinstance(h, dict):
            continue
        cmd = h.get("command")
        if isinstance(cmd, str) and cmd.startswith(BELVE_CMD_PREFIX):
            return True
    return False


def load_hooks() -> dict:
    if not HOOKS_FILE.exists():
        return {"hooks": {}}
    try:
        with open(HOOKS_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
    except Exception:
        # 既存ファイル壊れてる → backup して空でやり直し
        backup = HOOKS_FILE.with_suffix(".json.belve-broken")
        try:
            HOOKS_FILE.replace(backup)
            print(f"[codex-hooks-install] WARN: existing hooks.json malformed, backed up to {backup}", file=sys.stderr)
        except Exception:
            pass
        return {"hooks": {}}
    if not isinstance(data, dict):
        return {"hooks": {}}
    if "hooks" not in data or not isinstance(data["hooks"], dict):
        data["hooks"] = {}
    return data


def write_atomic(data: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    fd, tmp_path = tempfile.mkstemp(dir=str(CONFIG_DIR), prefix=".hooks.", suffix=".tmp")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2, ensure_ascii=False)
            f.write("\n")
        os.replace(tmp_path, HOOKS_FILE)
    except Exception:
        try:
            os.unlink(tmp_path)
        except FileNotFoundError:
            pass
        raise


def remove_belve(data: dict) -> dict:
    hooks_root = data["hooks"]
    for event in list(hooks_root.keys()):
        matchers = hooks_root.get(event) or []
        if not isinstance(matchers, list):
            continue
        kept = [m for m in matchers if not (isinstance(m, dict) and is_belve_owned(m))]
        if kept:
            hooks_root[event] = kept
        else:
            # Empty event 配列は削除 (= 元から無かった事にする)
            del hooks_root[event]
    return data


def install(data: dict) -> dict:
    # まず既存 Belve エントリを除去 (= upgrade 時の旧版残存対策)
    remove_belve(data)
    # 新規追加
    for event, subcmd, timeout in HOOKS_SPEC:
        new_matcher = {
            "hooks": [
                {
                    "type": "command",
                    "command": f"{BELVE_CMD_PREFIX} {subcmd}",
                    "timeout": timeout,
                }
            ]
        }
        existing = data["hooks"].get(event) or []
        if not isinstance(existing, list):
            existing = []
        existing.append(new_matcher)
        data["hooks"][event] = existing
    return data


def main() -> int:
    uninstall = "--uninstall" in sys.argv[1:]
    data = load_hooks()
    if uninstall:
        remove_belve(data)
    else:
        install(data)
    write_atomic(data)
    return 0


if __name__ == "__main__":
    sys.exit(main())
