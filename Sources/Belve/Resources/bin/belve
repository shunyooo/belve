#!/usr/bin/env bash
# Belve CLI - receives hook events from Claude Code and emits OSC to /dev/tty
#
# Usage: belve claude-hook <subcommand>
# Subcommands: session-start, notification, prompt-submit, stop, session-end

set -euo pipefail

PANE_ID="${BELVE_PANE_ID:-unknown}"

emit_event() {
    local status="$1"
    local message="$2"
    local osc
    osc=$(printf '\033]9;BELVE:%s:%s:%s\007' "$PANE_ID" "$status" "$message")
    # Write OSC to terminal: BELVE_TTY (explicit path), /dev/tty (controlling terminal), stderr (fallback)
    if [ -n "$BELVE_TTY" ] && [ -w "$BELVE_TTY" ]; then
        echo -n "$osc" > "$BELVE_TTY" 2>/dev/null
    elif echo -n "$osc" > /dev/tty 2>/dev/null; then
        :
    else
        echo -n "$osc" >&2 2>/dev/null || true
    fi
}

# Read and consume stdin (Claude Code sends JSON)
read_stdin() {
    cat > /dev/null 2>&1 || true
}

case "${1:-}" in
    claude-hook)
        case "${2:-}" in
            session-start)
                read_stdin
                emit_event "session_start" "started"
                ;;
            notification)
                # Parse notification type from stdin JSON
                local_msg="input needed"
                if command -v node > /dev/null 2>&1; then
                    local_msg=$(node -e '
                        let d="";
                        process.stdin.on("data",c=>d+=c);
                        process.stdin.on("end",()=>{
                            try{
                                const j=JSON.parse(d);
                                process.stdout.write(
                                    j.message ||
                                    j.notification_type ||
                                    j.title ||
                                    "input needed"
                                )
                            }
                            catch{process.stdout.write("input needed")}
                        })
                    ' 2>/dev/null) || local_msg="input needed"
                else
                    read_stdin
                fi
                emit_event "waiting" "$local_msg"
                ;;
            prompt-submit)
                # Capture prompt text for session label
                local_prompt=""
                if command -v node > /dev/null 2>&1; then
                    local_prompt=$(node -e '
                        let d="";
                        process.stdin.on("data",c=>d+=c);
                        process.stdin.on("end",()=>{
                            try{const j=JSON.parse(d);
                                const p=j.prompt||j.message||"";
                                process.stdout.write(p.substring(0,100).replace(/[\n\r"\\]/g," ").trim())}
                            catch{process.stdout.write("")}
                        })
                    ' 2>/dev/null) || local_prompt=""
                else
                    read_stdin
                fi
                if [ -n "$local_prompt" ]; then
                    emit_event "running" "$local_prompt"
                else
                    emit_event "running" "Generating"
                fi
                ;;
            pre-tool-use)
                # Capture tool name from stdin JSON
                local_tool=""
                if command -v node > /dev/null 2>&1; then
                    local_tool=$(node -e '
                        let d="";
                        process.stdin.on("data",c=>d+=c);
                        process.stdin.on("end",()=>{
                            try{const j=JSON.parse(d);
                                process.stdout.write(j.tool_name||j.tool||"")}
                            catch{process.stdout.write("")}
                        })
                    ' 2>/dev/null) || local_tool=""
                else
                    read_stdin
                fi
                if [ -n "$local_tool" ]; then
                    emit_event "running" "tool:$local_tool"
                fi
                ;;
            stop)
                read_stdin
                emit_event "completed" "Done"
                ;;
            session-end)
                read_stdin
                emit_event "session_end" "ended"
                ;;
            *)
                read_stdin
                ;;
        esac
        ;;
    *)
        echo "Usage: belve claude-hook <subcommand>" >&2
        exit 1
        ;;
esac
