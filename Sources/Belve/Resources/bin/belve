#!/usr/bin/env bash
# Belve CLI - receives hook events from Claude Code and emits OSC notifications
#
# Usage: belve claude-hook <subcommand>
# All subcommands read JSON from stdin and emit OSC 9 to the terminal.

set -euo pipefail

PANE_ID="${BELVE_PANE_ID:-unknown}"
# Stale session fallback: BELVE_PANE_ID が env に無い (= session が古いバージョンで
# 作られた) 場合、broker が書き出した per-session env file から読む。
# BELVE_SESSION_NAME は belve-persist が自動 export する session 識別子。
if [ "$PANE_ID" = "unknown" ] && [ -n "${BELVE_SESSION_NAME:-}" ]; then
    _envfile="/tmp/belve-session-env/${BELVE_SESSION_NAME}.env"
    if [ -f "$_envfile" ]; then
        _pid=$(grep '^BELVE_PANE_ID=' "$_envfile" | head -1 | cut -d= -f2-)
        [ -n "$_pid" ] && PANE_ID="$_pid"
    fi
fi
# Set on first parse_json call (= per-hook subprocess). 同 hook invocation で
# 後続 emit_event に session_id が乗る。OSC 形式 BELVE2 (= sessionId 付き) の
# ための前置情報。
SESSION_ID=""

emit_event() {
    local status="$1"
    local message="$2"
    local osc
    # 新 OSC 形式 (BELVE2) は paneId, sessionId, status, message の 4 セグメント。
    # NotificationStore はこの sessionId を使って「pane あたりの primary session」
    # を識別し、Stop hook で spawn された別 claude (= 別 session_id) からの通知を
    # 抑制する。session_id が空 (= 古い hook 等) の場合は「unknown」を入れて
    # 受信側で空扱いさせる。
    local sid="${SESSION_ID:-}"
    osc=$(printf '\033]9;BELVE2:%s:%s:%s:%s\007' "$PANE_ID" "$sid" "$status" "$message")
    if [ -n "${BELVE_TTY:-}" ] && [ -w "$BELVE_TTY" ]; then
        echo -n "$osc" > "$BELVE_TTY" 2>/dev/null
    elif echo -n "$osc" > /dev/tty 2>/dev/null; then
        :
    else
        echo -n "$osc" >&2 2>/dev/null || true
    fi
}

# Cache JSON payload from stdin (stdin can only be read once, so we buffer it
# in a variable and feed parse_json from echo).
JSON_PAYLOAD=""

# Read stdin once into JSON_PAYLOAD, then extract session_id. Subsequent
# parse_json calls operate on the cached payload.
read_payload() {
    JSON_PAYLOAD=$(cat 2>/dev/null || true)
    if [ -n "$JSON_PAYLOAD" ] && command -v node > /dev/null 2>&1; then
        SESSION_ID=$(printf '%s' "$JSON_PAYLOAD" | node -e "
            let d='';
            process.stdin.on('data',c=>d+=c);
            process.stdin.on('end',()=>{
                try{const j=JSON.parse(d);process.stdout.write(String(j.session_id||''))}
                catch{process.stdout.write('')}
            })
        " 2>/dev/null || echo "")
    fi
}

# Transcript polling: pre/post-tool-use hook から呼んで、前回以降の assistant
# message text を抽出 → 1 OSC で `speech` status として flush。Cursor (= 直前まで
# 読んだ line index) を per-session file に保存する。
# 複数の新 message があれば "\n\n" で連結して 1 OSC にまとめる (= TTY interleave 防止)。
flush_assistant_messages() {
    [ -z "${BELVE_SESSION_NAME:-}" ] && return 0
    [ -z "$JSON_PAYLOAD" ] && return 0
    command -v node > /dev/null 2>&1 || return 0
    local cursor_dir="/tmp/belve-session-env"
    local cursor_file="$cursor_dir/${BELVE_SESSION_NAME}.tsx-cursor"
    mkdir -p "$cursor_dir" 2>/dev/null || true
    local prev_cursor=""
    [ -f "$cursor_file" ] && prev_cursor=$(cat "$cursor_file" 2>/dev/null || echo "")
    local result
    result=$(printf '%s' "$JSON_PAYLOAD" | node -e "
        let d='';
        process.stdin.on('data',c=>d+=c);
        process.stdin.on('end',()=>{
            try {
                const j = JSON.parse(d);
                const tp = j.transcript_path || '';
                if (!tp) { process.stdout.write(''); return; }
                const fs = require('fs');
                const lines = fs.readFileSync(tp, 'utf8').split('\n').filter(Boolean);
                // cursor が未設定 (= Belve 再起動 or 初回) の場合、transcript 末尾に
                // 飛ばす (= 過去全文 push を防ぐ)。新 session なら lines=0 なので差なし。
                const rawCursor = '${prev_cursor}';
                const start = rawCursor === '' ? lines.length : parseInt(rawCursor, 10) || 0;
                if (start >= lines.length) {
                    process.stdout.write('___CURSOR___' + lines.length);
                    return;
                }
                // 範囲内の assistant text を「最後だけ」採用 (= claude stream の
                // partial / cumulative text で fragment 化するのを回避)。
                let lastText = '';
                for (let i = start; i < lines.length; i++) {
                    try {
                        const e = JSON.parse(lines[i]);
                        if (e.type === 'assistant') {
                            const blocks = (e.message||{}).content||[];
                            for (const b of blocks) {
                                if (b.type === 'text' && b.text && b.text.trim()) {
                                    lastText = b.text.trim();
                                }
                            }
                        }
                    } catch {}
                }
                let out = lastText;
                if (out) {
                    out = out.replace(/\r/g,'').replace(/\n/g,'\\\\n').replace(/\t/g,' ').replace(/[\x00-\x08\x0b-\x1f\x7f]/g,'').substring(0,4000);
                }
                process.stdout.write(out + '___CURSOR___' + lines.length);
            } catch { process.stdout.write(''); }
        })
    " 2>/dev/null || echo "")
    if [ -n "$result" ]; then
        local text="${result%___CURSOR___*}"
        local new_cursor="${result##*___CURSOR___}"
        [ -n "$new_cursor" ] && echo "$new_cursor" > "$cursor_file"
        if [ -n "$text" ]; then
            emit_event "running" "speech:$text"
        fi
    fi
}

# Parse cached JSON payload with node (no stdin reading).
parse_json() {
    local expr="$1"
    if [ -n "$JSON_PAYLOAD" ] && command -v node > /dev/null 2>&1; then
        printf '%s' "$JSON_PAYLOAD" | node -e "
            let d='';
            process.stdin.on('data',c=>d+=c);
            process.stdin.on('end',()=>{
                try{const j=JSON.parse(d);const r=(()=>{${expr}})();process.stdout.write(String(r||''))}
                catch{process.stdout.write('')}
            })
        " 2>/dev/null || echo ""
    else
        echo ""
    fi
}

case "${1:-}" in
    claude-hook)
        # Hook 内から spawn される子 claude が Belve hooks を inject しないように
        # 環境変数をセット。子 claude は claude wrapper でこれを見て pass-through する。
        export BELVE_HOOK_RUNNING=1
        # 全 hook subcommand 共通で stdin を一度だけ読み、session_id 抽出。
        read_payload
        case "${2:-}" in
            session-start)
                emit_event "session_start" "started"
                ;;

            session-end)
                emit_event "session_end" "ended"
                ;;

            prompt-submit)
                # \n / \r を literal "\n" (= 2 chars: backslash + n) に escape。
                # OSC payload 内の生改行はターミナル emulator が OSC を切る可能性が
                # あるため避ける。Mac 側 NotificationStore で復元する。
                msg=$(parse_json 'return (j.prompt||"").substring(0,2000).replace(/\r/g,"").replace(/\n/g,"\\n").trim()')
                emit_event "running" "${msg:-Generating}"
                ;;

            notification)
                msg=$(parse_json 'return j.message||j.notification_type||"input needed"')
                emit_event "waiting" "${msg:-input needed}"
                ;;

            pre-tool-use)
                # まず transcript の新 assistant message を flush (= tool 直前の中間発話)
                flush_assistant_messages
                msg=$(parse_json '
                    const t=j.tool_name||"";
                    const i=j.tool_input||{};
                    let detail="";
                    if(t==="Bash"||t==="bash") detail=String(i.command||"").substring(0,80).split("\n")[0];
                    else if(t==="Read"||t==="read") detail=String(i.file_path||i.path||"");
                    else if(t==="Write"||t==="write") detail=String(i.file_path||i.path||"");
                    else if(t==="Edit"||t==="edit") detail=String(i.file_path||i.path||"");
                    else if(t==="Grep"||t==="grep") detail=String(i.pattern||"");
                    else if(t==="Glob"||t==="glob") detail=String(i.pattern||"");
                    else if(t==="Agent"||t==="agent") detail=String(i.description||i.prompt||"").substring(0,60);
                    else if(t==="WebSearch") detail=String(i.query||"").substring(0,60);
                    else if(t==="WebFetch") detail=String(i.url||"").substring(0,60);
                    else detail=JSON.stringify(i).substring(0,60);
                    return t+(detail?":"+detail:"")
                ')
                [ -n "$msg" ] && emit_event "running" "tool:$msg"
                ;;

            post-tool-use)
                # tool 完了後に追加の assistant message があれば flush
                flush_assistant_messages
                msg=$(parse_json '
                    const t=j.tool_name||"";
                    const o=j.tool_output||j.output||"";
                    const s=String(o).substring(0,100).split("\n")[0].trim();
                    return t+(s?":"+s:"")
                ')
                [ -n "$msg" ] && emit_event "running" "result:$msg"
                ;;

            stop)
                # Send short completed event first (guaranteed to arrive)
                emit_event "completed" "Done"
                # Then try to extract and send the actual assistant response
                msg=$(parse_json '
                    const tp = j.transcript_path || "";
                    if (!tp) return "";
                    function extract() {
                        const lines = require("fs").readFileSync(tp, "utf8").trim().split("\n");
                        let lastUserIdx = -1;
                        for (let i = lines.length - 1; i >= 0; i--) {
                            const e = JSON.parse(lines[i]);
                            if (e.type === "user") {
                                const c = (e.message||{}).content||[];
                                if (!Array.isArray(c) || !c.some(b => b.type === "tool_result")) { lastUserIdx = i; break; }
                            }
                        }
                        let lastText = "";
                        for (let i = Math.max(0, lastUserIdx); i < lines.length; i++) {
                            const e = JSON.parse(lines[i]);
                            if (e.type === "assistant") {
                                for (const b of ((e.message||{}).content||[])) {
                                    if (b.type === "text" && b.text && b.text.trim()) lastText = b.text;
                                }
                            }
                        }
                        return lastText;
                    }
                    try {
                        let t = extract();
                        if (!t) { const{execSync:s}=require("child_process"); s("sleep 0.1"); t = extract(); }
                        if (t) return t.replace(/\r/g,"").replace(/\n/g,"\\n").replace(/\t/g," ").replace(/[\x00-\x08\x0b-\x1f\x7f]/g,"").substring(0,2000).trim();
                    } catch {}
                    return ""
                ')
                [ -n "$msg" ] && emit_event "completed" "$msg"
                ;;

            subagent-start)
                msg=$(parse_json 'return j.agent_type||j.description||j.name||"subagent"')
                emit_event "running" "subagent:$msg"
                ;;

            subagent-stop)
                msg=$(parse_json 'return j.agent_type||j.description||j.name||"subagent"')
                emit_event "running" "subagent-done:$msg"
                ;;

            *)
                cat > /dev/null
                ;;
        esac
        ;;
    *)
        echo "Usage: belve claude-hook <subcommand>" >&2
        exit 1
        ;;
esac
