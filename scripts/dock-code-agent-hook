// dock-code-agent-hook — Claude Code hook handler for dock-code
//
// Usage: dock-code-agent-hook <status> [message]
// Reads Claude Code hook JSON from stdin, writes event to dock-code events file.
// Only runs when DOCK_CODE_SESSION env var is set (i.e. inside dock-code terminal).

const [status, message] = process.argv.slice(2);
if (!status) {
	process.exit(0);
}

const eventsFile = '/tmp/dock-code-agent-events';
let input = '';

process.stdin.on('data', (chunk) => { input += chunk; });
process.stdin.on('end', () => {
	try {
		const hook = JSON.parse(input);
		const event = {
			source: 'terminal',
			eventType: 'claude-code',
			status,
			projectPath: hook.cwd,
			sessionId: hook.session_id,
			message: message || status,
		};
		require('fs').appendFileSync(eventsFile, JSON.stringify(event) + '\n');
	} catch {
		// Silently ignore parse errors
	}
});
